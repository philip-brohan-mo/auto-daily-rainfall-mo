# Azure ML workspace coordinates
# Copy this file to azureml/config.env, fill in your values, and
# scripts/aml_submit.sh will source it automatically.
#
# azureml/config.env is gitignored so your subscription ID is never committed.

# ── Workspace ─────────────────────────────────────────────────────────────────
AML_SUBSCRIPTION=
AML_RESOURCE_GROUP=
AML_WORKSPACE=

# ── Compute cluster ───────────────────────────────────────────────────────────
AML_COMPUTE=gpu-cluster

# ── Model ─────────────────────────────────────────────────────────────────────
# Short preset name ("smolvlm", "granite") or a full HuggingFace model ID.
WEATHER_MODEL=smolvlm

# ── Data paths ────────────────────────────────────────────────────────────────
# Base Azure ML datastore URI.  The workspace default store is:
#   azureml://datastores/workspaceblobstore/paths
# Change the datastore name if your data lives elsewhere.
AML_DATASTORE_BASE=azureml://datastores/workspaceblobstore/paths

# Paths relative to AML_DATASTORE_BASE for inputs.
AML_IMAGES_PATH=Daily_rainfall_sample/images
AML_TRANSCRIPTIONS_PATH=Daily_rainfall_sample/transcriptions

# Path relative to AML_DATASTORE_BASE where outputs are written.
# Each job appends its own sub-path (extractions/, eval/, checkpoints/).
AML_OUTPUTS_PATH=outputs

# Path relative to AML_DATASTORE_BASE for the persistent HuggingFace model cache.
# Shared across all jobs so model weights are only downloaded once.
AML_HF_CACHE_PATH=hf_cache
