outputs/
fake_daily_rainfall
test_data/
logs/

# Documentation
docs/
mkdocs.yml
README.md

# Tests (not needed at runtime)
tests/
.pytest_cache/

# Local environment files
environment.yml
condaenv.*.requirements.txt
azureml/config.env

# Dev tooling
.github/
.git/
.vscode/

# Python/local caches
__pycache__/
*.py[cod]
.mypy_cache/
.ruff_cache/
.coverage
.DS_Store
